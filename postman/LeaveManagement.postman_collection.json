{
  "info": {
    "name": "Leave Management API",
    "_postman_id": "9c653d93-7035-4b11-8e53-2fa9c2d3ea00",
    "description": "Collection for auth and leave APIs. Register/Login requests save JWT to environment token for subsequent GET/POST calls.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.request.headers.remove('Authorization');",
                  "if (!pm.environment.get('username')) {",
                  "  pm.environment.set('username', 'student_' + Date.now());",
                  "}",
                  "if (!pm.environment.get('role')) {",
                  "  pm.environment.set('role', 'STUDENT');",
                  "}",
                  "if ((pm.environment.get('role') === 'STUDENT' || pm.environment.get('role') === 'FACULTY') && !pm.environment.get('department')) {",
                  "  pm.environment.set('department', 'CSE');",
                  "}",
                  "if ((pm.environment.get('role') === 'STUDENT' || pm.environment.get('role') === 'FACULTY') && !pm.environment.get('section')) {",
                  "  pm.environment.set('section', 'A');",
                  "}",
                  "if ((pm.environment.get('role') === 'STUDENT' || pm.environment.get('role') === 'FACULTY') && !pm.environment.get('year')) {",
                  "  pm.environment.set('year', '2');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 400', function () {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Response time is acceptable', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "pm.test('Store token when registration succeeds', function () {",
                  "  if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body).to.have.property('role');",
                  "    pm.environment.set('token', body.token);",
                  "    pm.environment.set('role', body.role);",
                  "  }",
                  "});",
                  "pm.test('Show backend message for failed registration', function () {",
                  "  if (pm.response.code >= 400) {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('message');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"department\": \"{{department}}\",\n  \"section\": \"{{section}}\",\n  \"year\": \"{{year}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register?role={{role}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ],
              "query": [
                {
                  "key": "role",
                  "value": "{{role}}"
                }
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.request.headers.remove('Authorization');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response includes token and role', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('token');",
                  "  pm.expect(body).to.have.property('role');",
                  "  pm.environment.set('token', body.token);",
                  "  pm.environment.set('role', body.role);",
                  "});",
                  "pm.test('Response time is less than 3000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Leaves",
      "item": [
        {
          "name": "Get My Leaves",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/leaves/mine",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "leaves",
                "mine"
              ]
            }
          }
        },
        {
          "name": "Create Leave",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Response includes leave id/status fields', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('object');",
                  "  pm.expect(body).to.have.property('status');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Medical leave\",\n  \"fromDate\": \"2026-03-10\",\n  \"toDate\": \"2026-03-11\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/leaves",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "leaves"
              ]
            }
          }
        }
      ]
    }
  ]
}
